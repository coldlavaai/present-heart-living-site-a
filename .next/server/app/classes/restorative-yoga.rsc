d reset. The practice can be particularly supportive for individuals experiencing stress, fatigue or difficulty switching off."}],["$","p",null,{"children":"Sessions may also incorporate elements such as breath awareness or gentle sound to further enhance relaxation and calm."}],["$","p",null,{"children":"Regular practice often helps students experience improved sleep, reduced tension and a greater sense of balance in both body and mind."}]]}]}]}],["$","section",null,{"className":"bg-forest py-16 lg:py-20","children":["$","div",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center","children":[["$","h2",null,{"className":"text-white mb-4","children":"Ready to Try This Practice?"}],"$undefined",["$","div",null,{"className":"flex flex-col sm:flex-row gap-4 justify-center","children":[["$","$L5",null,{"href":"/contact","className":"inline-flex items-center justify-center px-6 py-3 rounded-lg font-semibold text-sm transition-colors no-underline bg-sage text-white hover:bg-forest ","children":"Book a Class"}],"$undefined"]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24 bg-mist/30","children":["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8","children":[["$","h2",null,{"className":"text-center mb-10","children":"Explore Other Classes"}],["$","div",null,{"className":"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6","children":[["$","$L5","Yin Yoga",{"href":"/classes/yin-yoga","className":"group block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow no-underline","children":[["$","div",null,{"className":"aspect-[3/2] bg-cover bg-center","style":{"backgroundImage":"url(https://images.unsplash.com/photo-1552196563-55cd4e45efb3?w=600&h=400&fit=crop)"},"role":"img","aria-label":"Yin yoga"}],["$","div",null,{"className":"p-6","children":[["$","h3",null,{"className":"text-forest group-hover:text-sage transition-colors mb-2","children":"Yin Yoga"}],"$L11","$L12"]}]]}],"$L13","$L14"]}]]}]}]],null,"$L15