ncouraging concentration and awareness."}],["$","p",null,{"children":"Seasonal Flow Yoga is suitable for both beginners and experienced practitioners who enjoy a more dynamic style of yoga. Movements can be modified to suit individual needs, allowing students to explore the practice at their own pace."}],["$","p",null,{"children":"Regular practice can support improved flexibility, greater strength and enhanced focus while helping students cultivate a steady and mindful approach to movement."}]]}]}]}],["$","section",null,{"className":"bg-forest py-16 lg:py-20","children":["$","div",null,{"className":"max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center","children":[["$","h2",null,{"className":"text-white mb-4","children":"Ready to Try This Practice?"}],"$undefined",["$","div",null,{"className":"flex flex-col sm:flex-row gap-4 justify-center","children":[["$","$L5",null,{"href":"/contact","className":"inline-flex items-center justify-center px-6 py-3 rounded-lg font-semibold text-sm transition-colors no-underline bg-sage text-white hover:bg-forest ","children":"Book a Class"}],"$undefined"]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24 bg-mist/30","children":["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8","children":[["$","h2",null,{"className":"text-center mb-10","children":"Explore Other Classes"}],["$","div",null,{"className":"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6","children":[["$","$L5","Restorative Yoga",{"href":"/classes/restorative-yoga","className":"group block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow no-underline","children":[["$","div",null,{"className":"aspect-[3/2] bg-cover bg-center","style":{"backgroundImage":"url(https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=600&h=400&fit=crop)"},"role":"img","aria-label":"Restorative yoga"}],"$L11"]}],"$L12","$L13"]}]]}]}]],null,"$L14"]}]
