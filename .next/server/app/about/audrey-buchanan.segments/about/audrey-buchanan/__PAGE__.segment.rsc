9:["$","section",null,{"className":"py-16 lg:py-24 bg-mist/30","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8","children":[["$","h2",null,{"className":"mb-6","children":"A Supportive Approach to Practice"}],["$","div",null,{"className":"prose text-peat/80 leading-relaxed space-y-6","children":[["$","p",null,{"children":"Audrey's teaching focuses on helping students develop awareness through movement and breath. Rather than encouraging performance or pushing the body beyond its limits, classes invite students to move in ways that feel supportive and sustainable. This approach allows individuals of all experience levels to explore yoga and mindful movement with confidence."}],["$","p",null,{"children":"Many students find that over time this style of practice supports not only greater physical strength and flexibility but also a deeper sense of calm and balance in everyday life."}]]}]]}]}]
