0:{"buildId":"ajONIM9fZCMCm4mPKPyPy","rsc":["$","$1","c",{"children":[[["$","section",null,{"className":"relative min-h-[40vh] lg:min-h-[50vh] flex items-center justify-center overflow-hidden","children":[["$","div",null,{"className":"absolute inset-0 bg-cover bg-center","style":{"backgroundImage":"url(https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=1600&h=900&fit=crop)"},"role":"img","aria-label":"Audrey Buchanan, yoga teacher"}],["$","div",null,{"className":"absolute inset-0 bg-gradient-to-t from-black/50 via-black/30 to-black/20"}],["$","div",null,{"className":"relative z-10 text-center px-4 max-w-4xl mx-auto","children":[["$","h1",null,{"className":"text-white text-3xl md:text-4xl lg:text-5xl font-heading font-normal mb-4 leading-tight","children":"Meet Audrey Buchanan"}],"$undefined","$undefined"]}]]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8","children":[["$","h2",null,{"className":"mb-6","children":"A Lifelong Practice"}],["$","div",null,{"className":"prose text-peat/80 leading-relaxed space-y-6","children":[["$","p",null,{"children":"Audrey Buchanan is the founder and teacher behind Present Heart Living. Her relationship with yoga began more than thirty years ago and has grown into a lifelong exploration of movement, mindfulness and wellbeing."}],["$","p",null,{"children":"For Audrey, yoga has never been simply about physical exercise. Instead, it has always been a practice of awareness — an opportunity to understand how the body moves, how the breath supports us and how moments of stillness can bring clarity to everyday life."}],["$","p",null,{"children":"This approach continues to shape the way she teaches today. Classes are designed to help students explore movement with curiosity and patience, creating space for both physical development and inner awareness."}]]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24 bg-mist/30","children":["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8","children":["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center ","children":[["$","div",null,{"className":"","children":["$","div",null,{"className":"aspect-[4/3] rounded-lg bg-cover bg-center","style":{"backgroundImage":"url(https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=800&h=600&fit=crop)"},"role":"img","aria-label":"Teaching yoga class"}]}],["$","div",null,{"className":"","children":[["$","h2",null,{"className":"mb-6","children":"Experience in Teaching and Education"}],["$","div",null,{"className":"prose text-peat/80 leading-relaxed space-y-4","children":[["$","p",null,{"children":"Before creating Present Heart Living, Audrey spent many years working in education as a primary teacher and later as a head teacher."}],["$","p",null,{"children":"This experience has had a strong influence on her teaching style. Audrey brings clarity, structure and patience into every class, helping students feel comfortable and supported as they learn."}],["$","p",null,{"children":"Her background in education also shapes the way she explains movement and breathing practices, ensuring that students can understand not only what they are doing but why those practices support their wellbeing."}]]}]]}]]}]}]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8","children":[["$","h2",null,{"className":"mb-6","children":"Training and Professional Development"}],["$","p",null,{"className":"text-peat/80 mb-6","children":"Audrey has completed extensive training in yoga and related wellbeing practices, including:"}],["$","ul",null,{"className":"space-y-3 text-peat/80","children":[["$","li",null,{"className":"flex items-start gap-3","children":[["$","span",null,{"className":"text-sage mt-1","children":"✦"}],"500 Hour Yoga Alliance recognised qualification"]}],"$L2","$L3","$L4","$L5","$L6"]}],"$L7","$L8"]}]}],"$