0:{"buildId":"ajONIM9fZCMCm4mPKPyPy","rsc":["$","$1","c",{"children":[[["$","section",null,{"className":"relative min-h-[40vh] lg:min-h-[50vh] flex items-center justify-center overflow-hidden","children":[["$","div",null,{"className":"absolute inset-0 bg-cover bg-center","style":{"backgroundImage":"url(https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=1600&h=900&fit=crop)"},"role":"img","aria-label":"Mindful yoga practice"}],["$","div",null,{"className":"absolute inset-0 bg-gradient-to-t from-black/50 via-black/30 to-black/20"}],["$","div",null,{"className":"relative z-10 text-center px-4 max-w-4xl mx-auto","children":[["$","h1",null,{"className":"text-white text-3xl md:text-4xl lg:text-5xl font-heading font-normal mb-4 leading-tight","children":"Teaching Philosophy and Training"}],"$undefined","$undefined"]}]]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8","children":[["$","h2",null,{"className":"mb-6","children":"A Philosophy of Awareness"}],["$","div",null,{"className":"prose text-peat/80 leading-relaxed space-y-6","children":[["$","p",null,{"children":"At Present Heart Living, yoga and mindful movement are approached as practices of awareness rather than performance."}],["$","p",null,{"children":"The intention of each class is to help students develop a deeper understanding of how their bodies move, how their breath supports that movement and how moments of stillness can bring balance to everyday life."}],["$","p",null,{"children":"Rather than focusing on achieving complex postures, the emphasis is on building a sustainable practice that supports strength, flexibility and resilience over time."}],["$","p",null,{"children":"Students are encouraged to move with attention, breathe with intention and approach the practice with curiosity and compassion. By developing awareness through movement and breath, individuals often discover that the benefits of yoga extend far beyond the mat."}],["$","p",null,{"children":"Over time, this approach can support greater physical wellbeing while also helping students navigate the demands of modern life with a greater sense of calm and clarity."}]]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24 bg-mist/30","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8","children":[["$","h2",null,{"className":"mb-6","children":"Inclusive and Supportive Teaching"}],["$","div",null,{"className":"prose text-peat/80 leading-relaxed space-y-6","children":[["$","p",null,{"children":"Present Heart Living is designed to be welcoming to people of all ages and experience levels."}],["$","p",null,{"children":"You do not need to be flexible or experienced to begin. Classes are structured to help students feel comfortable exploring movement at their own pace while learning the foundations of yoga and mindful movement."}],["$","p",null,{"children":"Modifications and variations are offered so that each student can practise in a way that feels appropriate for their body."}],["$","p",null,{"children":"This supportive approach allows individuals to develop confidence gradually while discovering the benefits of regular practice."}]]}]]}]}],["$","section",null,{"className":"py-16 lg:py-24","children":["$","div",null,{"className":"max-w-3xl mx-auto px-4 sm:px-6 lg:px-8","children":[["$","h2",null,{"className":"mb-6","children":"Professional Training and Qualifications"}],["$","div",null,{"className":"prose text-peat/80 leading-relaxed space-y-6","children":[["$","p",null,{"children":"The teaching approach at Present Heart Living is supported by extensive training and ongoing professional development."}],["$","p",null,{"children":"Audrey Buchanan holds a 500 Hour Yoga Alliance recognised qualification and has trained in several complementary practices that support holistic wellbeing."}]]}],"$L2","$L3","$L4"]}]}],"$L5","$L6"],null,"$L7"]}],"loading":null,"isPartial":false}
